# Puerto del servidor web (panel de administracion / API)
PORT=3000

# Clave simple para proteger los endpoints de la API (cambia esto)
API_KEY=cambia-esta-clave-super-secreta

# Nombre del negocio (se usa en mensajes automaticos)
BUSINESS_NAME="Mi Negocio"

# Limite de mensajes de promocion por minuto (para evitar bloqueo de WhatsApp)
BROADCAST_RATE_PER_MINUTE=8

# Segundos de espera minimos entre cada mensaje de broadcast (ademas del rate limit)
BROADCAST_MIN_DELAY_SECONDS=4

# Horario de atencion del chatbot automatico (formato 24h)
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=18:00
